<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Spring Boot console defaults: honours logging.pattern.console (incl. [%X{requestId}]) -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!--
        File logging is enabled only when app.log.path is set. LoggingFileEnvironmentPostProcessor
        activates the "file-logging" profile and provides LOG_FILE + FILE_LOG_LEVEL. The console
        appender stays verbose; only the FILE appender is filtered per environment (dev/qa/prod).

        <springProfile> must live at the top level (it cannot be nested inside <root>), so each
        branch declares its own complete <root>.
    -->
    <springProfile name="file-logging">
        <springProperty name="LOG_FILE" source="LOG_FILE"/>
        <springProperty name="FILE_LOG_LEVEL" source="FILE_LOG_LEVEL"/>

        <appender name="FILE" class="ch.qos.logback.core.FileAppender">
            <file>${LOG_FILE}</file>
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>${FILE_LOG_LEVEL}</level>
            </filter>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [%X{requestId}] %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <springProfile name="!file-logging">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>
